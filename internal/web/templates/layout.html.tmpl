{{define "layout"}}<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}} · seedstorm</title>
  <link rel="stylesheet" href="/static/style.css">
  <script src="/static/lib/htmx.min.js" defer></script>
  <script src="/static/lib/cytoscape.min.js" defer></script>
  <script src="/static/lib/dagre.min.js" defer></script>
  <script src="/static/lib/cytoscape-dagre.js" defer></script>
  <script src="/static/app.js" defer></script>
</head>
<body data-active="{{.Active}}">
  <header class="topbar">
    <div class="brand">
      <span class="logo" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="seedstorm-logo-grad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
              <stop offset="0" stop-color="#79d8b3"/>
              <stop offset="1" stop-color="#d8b56f"/>
            </linearGradient>
          </defs>
          <path d="M 26 16 A 10 10 0 1 1 16 6" stroke="url(#seedstorm-logo-grad)" stroke-width="2.4" stroke-linecap="round"/>
          <path d="M 22 16 A 6 6 0 1 1 16 10"  stroke="url(#seedstorm-logo-grad)" stroke-width="2.4" stroke-linecap="round"/>
          <circle cx="16" cy="16" r="1.8" fill="url(#seedstorm-logo-grad)"/>
        </svg>
      </span>
      <span>seedstorm</span>
    </div>
    <nav class="nav">
      {{if .Session}}
        <a href="/"         class="navlink {{if eq .Active "workspace"}}active{{end}}">Workspace</a>
        <a href="/generate" class="navlink {{if eq .Active "generate"}}active{{end}}">Generate</a>
        <a href="/enrich"   class="navlink {{if eq .Active "enrich"}}active{{end}}">AI Enrich</a>
        <a href="/export"   class="navlink {{if eq .Active "export"}}active{{end}}">Export</a>
      {{end}}
    </nav>
    <div class="session">
      {{if .Session}}
        <details class="conn-switcher">
          <summary class="conn-pill" title="{{.Session.Info.DBType}}://{{.Session.Info.User}}@{{.Session.Info.Host}}:{{.Session.Info.Port}}/{{.Session.Info.DBName}}">
            <span class="conn-dot {{.Session.Info.DBType}}"></span>
            <span class="conn-label">{{connName .Session.Info}}</span>
            <span class="muted small">@{{.Session.Info.Host}}</span>
            <span class="caret">▾</span>
          </summary>
          <div class="conn-menu">
            <div class="conn-menu-list">
              {{range .Connections}}
                <form method="post" action="/switch" class="conn-menu-row {{if eq .ID $.Session.ID}}active{{end}}">
                  <input type="hidden" name="id" value="{{.ID}}">
                  <button type="submit" class="conn-menu-btn" {{if eq .ID $.Session.ID}}disabled{{end}}>
                    <span class="conn-dot {{.Info.DBType}}"></span>
                    <div class="conn-menu-text">
                      <strong>{{connName .Info}}</strong>
                      <span class="muted small">{{.Info.User}}@{{.Info.Host}}:{{.Info.Port}}</span>
                    </div>
                    {{if eq .ID $.Session.ID}}<span class="muted small">active</span>{{end}}
                  </button>
                </form>
              {{end}}
            </div>
            <div class="conn-menu-list conn-preset-list" id="conn-preset-list"></div>
            <div class="conn-menu-actions">
              <a class="btn-ghost" href="/connect">+ New connection</a>
              <a class="btn-ghost" href="/disconnect">Disconnect this</a>
            </div>
          </div>
        </details>
      {{else}}
        <a class="btn-primary" href="/connect">Connect</a>
      {{end}}
    </div>
  </header>
  <main class="main">
    {{if .Error}}<div class="flash flash-error">{{.Error}}</div>{{end}}
    {{if .Flash}}<div class="flash flash-ok">{{.Flash}}</div>{{end}}
    {{template "content" .}}
  </main>
</body>
</html>
{{end}}

{{define "joblog"}}
<div class="job-panel" id="job-panel" hidden>
  <div class="row spread">
    <div class="row">
      <span class="status-pill" id="job-status">idle</span>
      <span class="muted small" id="job-elapsed"></span>
      <span class="muted" id="job-name"></span>
    </div>
    <div class="row">
      <button class="btn-ghost" id="job-expand-all" type="button" title="Expand or collapse every phase">⤢</button>
      <button class="btn-ghost" id="job-cancel" type="button" disabled>Cancel</button>
      <button class="btn-ghost" id="job-clear"  type="button">Clear</button>
    </div>
  </div>
  <div class="job-progress-wrap" id="job-progress-wrap" hidden>
    <progress class="job-progress" id="job-progress" max="100" value="0"></progress>
    <span class="muted small" id="job-progress-label"></span>
  </div>
  <div class="job-phases" id="job-phases"></div>
  <div id="job-result"></div>
</div>
{{end}}
