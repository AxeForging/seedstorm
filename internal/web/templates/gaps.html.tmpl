{{define "content"}}
<section class="card stack">
  <h1>Gaps</h1>
  <p class="muted">Find tables with zero rows and optionally fill them while preserving FK references to already-populated parents.</p>
  <form id="run-form" data-endpoint="/api/gaps" class="grid-2">
    <label class="field">
      <span class="field-label">Rows per empty table</span>
      <input name="rows" type="number" value="100" min="1">
    </label>
    <label class="field">
      <span class="field-label">Batch size</span>
      <input name="batchSize" type="number" value="100" min="1">
    </label>
    <label class="field row inline">
      <input name="fill" type="checkbox"> Fill empty tables
    </label>
    <label class="field row inline">
      <input name="dryRun" type="checkbox"> Dry run
    </label>
    <div class="span-2 actions">
      <button class="btn-primary" type="submit">Analyze gaps</button>
    </div>
  </form>
  {{template "joblog" .}}
</section>
{{end}}
