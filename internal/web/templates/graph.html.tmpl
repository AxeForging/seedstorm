{{define "content"}}
<section class="card stack">
  <header class="row spread">
    <h1>Dependency graph</h1>
    <div class="row">
      <button class="btn-ghost" id="graph-fit">Fit</button>
      <button class="btn-ghost" id="graph-relayout">Re-layout</button>
    </div>
  </header>
  <p class="muted">Solid edges are hard FK dependencies (parent must seed first). Dashed edges are nullable FKs — they don't constrain order.</p>
  <div id="cy" class="graph-canvas"></div>
  <div id="graph-order" class="muted small"></div>
</section>
{{end}}
