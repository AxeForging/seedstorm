{{define "content"}}
<section class="connect-shell">
  <aside class="connect-visual" aria-hidden="true">
    <div class="connect-orbit">
      <div class="orbit-ring ring-a"></div>
      <div class="orbit-ring ring-b"></div>
      <div class="orbit-core">
        <span>seed</span>
        <strong>storm</strong>
      </div>
      <div class="orbit-node node-a"></div>
      <div class="orbit-node node-b"></div>
      <div class="orbit-node node-c"></div>
    </div>
    <div class="connect-signal">
      <div class="signal-row"><span>schema.scan</span><strong>ready</strong></div>
      <div class="signal-row"><span>fk.graph</span><strong>locked</strong></div>
      <div class="signal-row"><span>faker.map</span><strong>armed</strong></div>
    </div>
  </aside>

  <section class="connect-panel">
    <div class="connect-head">
      <span class="eyebrow">local database workspace</span>
      <h1>Connect to your seed target</h1>
      <p>Passwords stay in process memory. Presets live only in this browser and can skip secrets when needed.</p>
    </div>

    <div class="preset-strip">
      <label class="field">
        <span class="field-label">Saved presets</span>
        <select id="preset-picker">
          <option value="">none</option>
        </select>
      </label>
      <button class="btn-ghost" id="preset-delete" type="button" disabled>Delete</button>
    </div>

    <form method="post" action="/connect" id="connect-form" class="connect-form">
      <input name="label" id="connection-label" type="hidden">
      <label class="field">
        <span class="field-label">Driver</span>
        <select name="dbType" required>
          <option value="postgres">PostgreSQL</option>
          <option value="mysql">MySQL</option>
        </select>
      </label>
      <label class="field">
        <span class="field-label">SSL mode</span>
        <select name="ssl">
          <option value="disable">disable</option>
          <option value="require">require</option>
          <option value="verify-ca">verify-ca</option>
          <option value="verify-full">verify-full</option>
        </select>
      </label>

      <label class="field span-2">
        <span class="field-label">Connection string</span>
        <input name="dsn" placeholder="optional: postgres://user:pass@host:5432/db or user:pass@tcp(host:3306)/db">
      </label>

      <label class="field">
        <span class="field-label">Host</span>
        <input name="host" value="localhost" required>
      </label>
      <label class="field">
        <span class="field-label">Port</span>
        <input name="port" type="number" value="5432" required>
      </label>

      <label class="field">
        <span class="field-label">Database</span>
        <input name="dbName" required placeholder="testdb">
      </label>
      <label class="field">
        <span class="field-label">User</span>
        <input name="user" required placeholder="seedstorm">
      </label>

      <label class="field span-2">
        <span class="field-label">Password</span>
        <span class="input-eye">
          <input name="password" id="conn-password" type="password" autocomplete="off">
          <button type="button" id="toggle-password" class="eye-btn" aria-label="Reveal password" data-revealed="false">
            <svg class="eye-icon eye-icon-open" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg class="eye-icon eye-icon-closed" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/></svg>
          </button>
        </span>
      </label>

      <label class="field span-2">
        <span class="field-label">Save preset as</span>
        <span class="preset-save">
          <input id="preset-name" placeholder="optional preset name">
          <label class="preset-check" title="Saved unencrypted in this browser's localStorage. Only do this on machines you trust.">
            <input id="preset-include-pw" type="checkbox" checked>
            <span>include password</span>
          </label>
        </span>
      </label>

      <div class="connect-actions span-2">
        <button class="btn-primary btn-connect" type="submit">
          <span>Connect</span>
          <span class="btn-arrow" aria-hidden="true">→</span>
        </button>
        <span class="muted small">The next screen builds the graph workspace from the live schema.</span>
      </div>
    </form>
  </section>
</section>
{{end}}
