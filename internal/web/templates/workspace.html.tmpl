{{define "content"}}
<section class="workspace">
  <aside class="ws-rail">
    <header class="ws-rail-head">
      <h2>Workspace</h2>
      <p class="muted small">Select tables from the graph. Required parents are added automatically.</p>
    </header>

    <div class="ws-stats" aria-label="Schema summary">
      <div>
        <span class="ws-stat-value" id="ws-stat-tables">0</span>
        <span class="ws-stat-label">tables</span>
      </div>
      <div>
        <span class="ws-stat-value" id="ws-stat-empty">0</span>
        <span class="ws-stat-label">empty</span>
      </div>
      <div>
        <span class="ws-stat-value" id="ws-stat-populated">0</span>
        <span class="ws-stat-label">with rows</span>
      </div>
    </div>

    <div class="ws-toolbar">
      <label class="ws-search">
        <span class="sr-only">Find table</span>
        <input id="ws-search" type="search" placeholder="Find table">
        <kbd>/</kbd>
      </label>
      <button class="btn-ghost" data-act="all">Select all</button>
      <button class="btn-ghost" data-act="empty">Empty</button>
      <button class="btn-ghost" data-act="none">Unselect all</button>
      <button class="btn-ghost" data-act="invert">Invert</button>
      <button class="btn-ghost" data-act="refresh" title="Refresh row counts">↻</button>
    </div>

    <div class="ws-tabs">
      <button class="ws-tab active" data-tab="selected">Selected</button>
      <button class="ws-tab" data-tab="detail">Table</button>
      <button class="ws-tab" data-tab="logs">Logs</button>
    </div>

    <div class="ws-tab-body" data-tab="selected">
      <div class="ws-counter">
        <span id="ws-count-selected">0</span> selected ·
        <span id="ws-count-auto">0</span> auto-locked ·
        <span id="ws-count-total">0</span> total
      </div>
      <div class="ws-scope" id="ws-scope">Run scope: all tables</div>
      <p class="muted small ws-tip">Use <strong>Peek</strong> for inline rows, or <strong>Open</strong> for the full paginated table.</p>
      <ol class="ws-selected-list" id="ws-selected-list"></ol>
      <p class="muted small empty-hint" id="ws-selected-empty">No explicit selection. Run applies to every table; click nodes or choose <kbd>Empty</kbd> to narrow the scope.</p>
    </div>

    <div class="ws-tab-body" data-tab="detail" hidden>
      <div id="ws-detail">
        <p class="muted small empty-hint">Right-click a table or use the info button to inspect its columns.</p>
      </div>
    </div>

    <div class="ws-tab-body" data-tab="logs" hidden>
      <div class="row spread">
        <div class="row">
          <span class="status-pill" id="job-status">idle</span>
          <span class="muted small" id="job-elapsed"></span>
        </div>
        <div class="row">
          <button class="btn-ghost" id="job-expand-all" type="button" title="Expand or collapse every phase">⤢</button>
          <button class="btn-ghost" id="job-cancel" type="button" disabled>Cancel</button>
        </div>
      </div>
      <div class="job-progress-wrap" id="job-progress-wrap" hidden>
        <progress class="job-progress" id="job-progress" max="100" value="0"></progress>
        <span class="muted small" id="job-progress-label"></span>
      </div>
      <div class="job-phases" id="job-phases"></div>
      <div id="job-result"></div>
    </div>
  </aside>

  <div class="ws-canvas-wrap">
    <div class="ws-canvas-tools" aria-label="Graph controls">
      <div class="ws-route-toggle" aria-label="Edge routing">
        <button class="btn-ghost active" data-route="straight" type="button" title="Straight relationships">Straight</button>
        <button class="btn-ghost" data-route="smooth" type="button" title="Smooth bezier relationships">Smooth</button>
        <button class="btn-ghost" data-route="step" type="button" title="Orthogonal step relationships">Step</button>
      </div>
      <button class="btn-ghost" id="ws-fit" type="button" title="Fit graph">Fit</button>
      <button class="btn-ghost" id="ws-zoom-in" type="button" title="Zoom in">+</button>
      <button class="btn-ghost" id="ws-zoom-out" type="button" title="Zoom out">-</button>
    </div>
    <div id="cy" class="ws-canvas"></div>
    <div class="ws-legend muted small">
      <span><i class="dot dot-sel"></i> selected</span>
      <span><i class="dot dot-auto"></i> auto-locked parent</span>
      <span><i class="dot dot-empty"></i> empty</span>
      <span><i class="dot dot-pop"></i> populated</span>
      <span><i class="line line-solid"></i> hard FK</span>
      <span><i class="line line-dashed"></i> nullable FK</span>
    </div>
  </div>

  <footer class="ws-actionbar">
    <div class="ws-run-group ws-run-modes">
      <span class="ws-run-label">Mode</span>
      <div class="ws-mode" role="tablist" aria-label="Run mode">
        <button class="ws-mode-pill active" data-mode="seed" type="button">
          <strong>Seed</strong>
          <span>write rows</span>
        </button>
        <button class="ws-mode-pill" data-mode="gaps" type="button">
          <strong>Fill empty</strong>
          <span>only gaps</span>
        </button>
        <button class="ws-mode-pill" data-mode="generate" type="button">
          <strong>Generate</strong>
          <span>no DB write</span>
        </button>
      </div>
    </div>
    <div class="ws-config ws-run-group">
      <span class="ws-run-label">Volume</span>
      <label class="field-tight">
        <span>Rows</span>
        <input id="cfg-rows" type="number" value="20" min="1">
      </label>
      <label class="field-tight">
        <span>Batch</span>
        <input id="cfg-batch" type="number" value="100" min="1">
      </label>
      <label class="field-tight">
        <span>Enum/value</span>
        <input id="cfg-enum" type="number" value="0" min="0">
      </label>
      <label class="field-tight">
        <span>Self-ref</span>
        <input id="cfg-selfref-depth" type="number" value="2" min="0">
      </label>
    </div>
    <div class="ws-run-group ws-risk">
      <span class="ws-run-label">Options</span>
      <label class="field-tight inline">
        <input id="cfg-truncate" type="checkbox"> truncate
      </label>
      <label class="field-tight inline">
        <input id="cfg-dryrun"   type="checkbox"> dry-run
      </label>
      <label class="field-tight inline">
        <input id="cfg-disablefk" type="checkbox"> disable FK
      </label>
    </div>
    <button class="btn-primary" id="ws-run">Run all tables</button>
  </footer>

  <div class="table-modal" id="table-modal" hidden>
    <div class="table-modal-backdrop" data-modal-close></div>
    <section class="table-modal-panel" role="dialog" aria-modal="true" aria-labelledby="table-modal-title">
      <header class="table-modal-head">
        <div>
          <span class="eyebrow">live table preview</span>
          <h2 id="table-modal-title">Table</h2>
          <p class="muted small" id="table-modal-meta">Loading rows...</p>
        </div>
        <div class="row">
          <button class="btn-ghost" id="table-modal-refresh" type="button">Refresh</button>
          <button class="btn-ghost" id="table-modal-close" type="button" aria-label="Close table preview">Close</button>
        </div>
      </header>
      <div class="table-modal-controls">
        <label class="field-tight inline">
          <span>Limit</span>
          <select id="table-modal-limit">
            <option value="25">25</option>
            <option value="50" selected>50</option>
            <option value="100">100</option>
          </select>
        </label>
        <label class="field-tight inline preview-toggle">
          <input id="table-modal-hide-null" type="checkbox">
          hide NULL-only columns
        </label>
        <span class="muted small" id="table-modal-note"></span>
      </div>
      <div class="table-modal-body" id="table-modal-body">
        <p class="muted small empty-hint">Loading rows...</p>
      </div>
      <footer class="table-modal-foot">
        <button class="btn-ghost" id="table-modal-prev" type="button">Previous</button>
        <span class="muted small" id="table-modal-page"></span>
        <button class="btn-ghost" id="table-modal-next" type="button">Next</button>
      </footer>
    </section>
  </div>
</section>
{{end}}
